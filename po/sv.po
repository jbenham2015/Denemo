#: ../src/command/scorelayout.c:1978
msgid "This contains the layout of the movement- the movement title, and the actual music itself"
msgstr "Här finns satsns layout - satsns titel och själva musiken"

#: ../src/command/scorelayout.c:1989
msgid "Remove this movement from the score layout"
msgstr "Ta bort denna sats från partiturlayouten"

#: ../src/command/scorelayout.c:2012
msgid "Header block"
msgstr "Huvudblock"

#: ../src/command/scorelayout.c:2034
