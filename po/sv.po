msgstr "Rörelseblock"

#: ../src/command/scorelayout.c:2081
msgid "Movement Epilog"
msgstr "Rörelsens epilog"

#: ../src/command/scorelayout.c:2137
msgid "The currently expanded movement is already at the end"
msgstr "Den nuvarande utvidgade satsn är redan i slutet"

