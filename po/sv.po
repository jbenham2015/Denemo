msgid "Breve"
msgstr "Breve"

#: ../actions/menus/ObjectMenu/NotesRests/ChangeDuration/ChangeBreve.xml.h:2
msgid "Change current note duration to Breve"
msgstr "Ändra aktuell notlängd till Breve"

#. not a chord
