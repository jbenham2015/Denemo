msgid "Basic Distance Apart"
msgstr "Grundläggande avstånd från varandra"

#: ../actions/menus/ObjectMenu/Score/Typesetter/PrintLayout/VerticalSpacing/Staff-Spacing/StaffToStaffSpacing.scm:11
msgid "Minimum Distance Apart"
msgstr "Minsta avstånd från varandra"

#: ../actions/menus/ObjectMenu/Score/Typesetter/PrintLayout/VerticalSpacing/Staff-Spacing/StaffToStaffSpacing.scm:13
msgid "Stretchabilty"
msgstr "Sträckbarhet"

#: ../actions/menus/ObjectMenu/Score/Typesetter/PrintLayout/VerticalSpacing/Staff-Spacing/StaffToStaffSpacing.scm:18
