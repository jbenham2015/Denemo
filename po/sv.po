msgid "Shows the history of print outs for this score. Only saved documents have their printing recorded"
msgstr "Visar historiken över utskrifter för denna poäng. Endast sparade dokument har sina utskrifter registrerade"

#: ../src/core/entries.h:254
msgid "Print Part"
msgstr "Skriv ut del"

#: ../src/core/entries.h:254
msgid "Typesets the current part (the one containing the cursor)."
msgstr "Skriver den aktuella delen (den som innehåller markören)."

#: ../src/core/entries.h:255
msgid "Indexing"
msgstr "Indexering"

