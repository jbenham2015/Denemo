msgstr "dim. början borttagen. Slutet diminuendo bör också raderas ..."

#: ../actions/menus/ObjectMenu/NotesRests/Markings/Dynamics/Dim.xml.h:1
msgid "Dim (Off/On)"
msgstr "Dim (Av/På)"

