msgstr "Ge char(s) för linjestart utseende"

#: ../actions/menus/ObjectMenu/Score/Typesetter/CustomBarline.scm:41
msgid "Give char(s) for line end appearance"
msgstr "Ge char(s) för utseende i slutet av linjen"

